<!DOCTYPE html>
<html>
<head>
    <title>Image Switch using Mouse Events</title>

    <script>
        // Function to change image when mouse is over
        function changeImage() {
            document.getElementById("myImage").src = "image2.jpg";
        }

        // Function to restore original image when mouse leaves
        function restoreImage() {
            document.getElementById("myImage").src = "image1.jpg";
        }
    </script>

</head>

<body>

<h2>Move Mouse Over the Image</h2>

<img id="myImage"
     src="image1.jpg"
     width="300"
     height="200"
     onmouseover="changeImage()"
     onmouseout="restoreImage()">

</body>
</html>
